# Copy to .env and point it at your running FastAPI backend.
# The EXPO_PUBLIC_ prefix exposes it to the app at build time.
#
# IMPORTANT: a phone running Expo Go can't reach "localhost" — use your
# computer's LAN IP (e.g. http://192.168.1.20:8000). For the iOS simulator
# http://localhost:8000 works; for the Android emulator use http://10.0.2.2:8000.
EXPO_PUBLIC_API_URL=http://192.168.1.20:8000
